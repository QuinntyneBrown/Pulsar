{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Temperature Reading",
  "type": "object",
  "properties": {
    "sensorId": { "type": "string", "minLength": 1, "default": "sensor-temp-1" },
    "celsius": { "type": "number", "minimum": -273.15, "default": 21.5 },
    "recentSamples": { "type": "array", "items": { "type": "number" } }
  },
  "required": ["sensorId", "celsius"]
}
